# Copy this file to .env and fill in values.
# All EXPO_PUBLIC_* vars are bundled into the client app — never put secrets here.

# Supabase ----------------------------------------------------------------
# Local dev (after `supabase start`):
#   URL is printed by `supabase start`; default is http://127.0.0.1:54321
#   ANON_KEY is also printed by `supabase start`
# Production:
#   Find both in your Supabase project dashboard under Settings → API
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox ------------------------------------------------------------------
# Create a token at https://account.mapbox.com/access-tokens/
# URL-restrict it once the app has a deployed domain.
EXPO_PUBLIC_MAPBOX_TOKEN=
